SQL JOINS

= Used to combine data of related tables using a common column

syntax:
select * from table1 join table2 on table1.common_column=table2.common_column

1. students to results
select * from students as s join results as r on s.id=r.student_id;
2. join staff to courses
select * from staff as st join courses as c on st.id=c.staff_id;
3. join students with enrollments
 select * from students as s join enrollments as en on s.id=en.student_id;
4. join courses to enrollments
 select * from courses as c join enrollments as en on c.id=en.course_id;

