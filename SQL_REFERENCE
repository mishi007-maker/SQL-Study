10.find total sales of each product...

SELECT p.productname,p.productid, sum(p.price*ord.quantity) as total_sales FROM Products as p left join orderdetails as ord on p.productid=ord.productid group by p.productid,p.productname;

11.find total sales made in the year 1997.

SELECT sum(p.price*ord.quantity) as total_sales FROM Orders as o inner join orderdetails as ord on o.orderid=ord.orderid inner join products as p on p.productid=ord.productid where year (o.orderdate)=1997;

