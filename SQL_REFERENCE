2.Display : OrderId, OrderDate, CustomerName, City, Address, PostalCode, ShipperName, ProductName, Quantity.

SELECT Orders.OrderID,Orders.OrderDate,Customers.CustomerName,Customers.City,customers.Address,Customers.PostalCode,Shippers.ShipperName,Products.ProductName,OrderDetails.Quantity FROM Orders INNER JOIN Customers ON Orders.CustomerID = Customers.CustomerID INNER JOIN Shippers ON Orders.ShipperID = Shippers.ShipperID INNER JOIN OrderDetails ON Orders.OrderID = OrderDetails.OrderID INNER JOIN Products ON OrderDetails.ProductID = Products.ProductID;


3.Display all products ever been ordered and display the shipper name.


SELECT Products.ProductName,Shippers.ShipperName FROM Products
INNER JOIN OrderDetails ON Products.ProductID=OrderDetails.ProductID
INNER JOIN Orders ON OrderDetails.OrderID = Orders.OrderID INNER JOIN Shippers ON Orders.ShipperID = Shippers.ShipperID;


4.How many customers DO NOT have the words ‘son’ in their CustomerName.

SELECT COUNT(*) AS CustomersWithoutSon FROM Customers WHERE CustomerName NOT LIKE '%son%';

6.Display each customer_name and total_amount ever spent in the business, from highest amount.

SELECT c.customername,c.customerid,sum(p.price*ord.quantity) as total_amount FROM customers as c inner join orders as o on c.customerid=o.customerid inner join orderdetails as ord on o.orderid=ord.orderid inner join products as p on ord.productid=p.productid group by c.customerid, c.customername order by sum(p.price*ord.quantity) desc;

7.Find total sales per day.

SELECT o.orderdate as sales_date, sum(price*ord.quantity) as total_sales FROM Orders as o inner join orderdetails as ord on o.orderid=ord.orderid inner join products as p on p.productid=ord.productid group by o.orderdate;

8.Find the total sales for each customer,the ones who have never ordered leave as 0.

SELECT c.customername,c.customerid,sum(price*ord.quantity) as o FROM Customers as c left join orders as o on c.customerid=o.customerid left join orderdetails as ord on ord.orderid=o.orderid left join products as p on p.productid=ord.productid group by sum(price*ord.quantity) order by c.customerid,c.customername;

