12.show total quantity ordered per product.

SELECT p.productid,sum(ord.quantity) as total_quantity,p.productname FROM Products as p join orderdetails as ord on p.productid=ord.productid group by p.productid,p.productname;

13.show total orders per customer.

SELECT c.customerid,c.customername, count(o.orderid) as total_orders FROM Customers as c inner join orders as o on c.customerid=o.customerid group by c.customerid,c.customername;

14.show total sales amount per product.

SELECT p.productid,p.productname, sum(p.price*ord.quantity) as total_sales FROM  products as p inner join orderdetails as ord on ord.productid=p.productid group by p.productid.p.productname;

15.show category and total products in each category.

SELECT cat.categoryid,cat.categoryname,count(p.productid) as total_products FROM Products as p inner join categories as cat on p.categoryid=cat.categoryid group by cat.categoryid,cat.categoryname;

16.top 5 customers by total purchase amount.

select TOP 5 c.customerid,c.customername,sum(p.price*ord.quantity) as total_purchase from customers as c inner join orders as o on o.customerid=c.customerid inner join orderdetails as ord on o.orderid=ord.orderid inner join products as p on p.productid=ord.productid group by c.customerid,c.customername order by sum(p.price*ord.quantity) desc;

17.employee and number of orders handled.

SELECT e.employeeid, e.firstname,count(orderid) as total_orders_handled FROM Orders as o inner join employees as e on o.employeeid=e.employeeid group by e.employeeid,e.firstname;

18.total revenue per category.

SELECT c.categoryid,c.categoryname,sum(p.price*ord.quantity) as total_revenue FROM Products as p inner join categories as c on c.categoryid=p.categoryid inner join orderdetails as ord on p.productid=ord.productid group by c.categoryid,c.categoryname;

19.most sold product (by quantity).

SELECT top 1 p.productid,p.productname, count(ord.quantity) as most_sold_product FROM OrderDetails as ord inner join products as p on ord.productid=p.productid group by p.productid,p.productname order by most_sold_product desc;

20.Employee who generated the highest sales.

SELECT top 1 e.employeeid,e.firstname,sum(p.price*ord.quantity) as highest_sales FROM Employees as e inner join orders as o on o.employeeid=e.employeeid inner join orderdetails as ord on o.orderid=ord.orderid inner join products as p on p.productid=ord.productid group by e.employeeid,e.firstname order by sum(p.price*ord.quantity) desc;